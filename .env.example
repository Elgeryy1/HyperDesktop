POSTGRES_DB=hyperdesk
POSTGRES_USER=hyperdesk
POSTGRES_PASSWORD=hyperdesk
DATABASE_URL=postgresql://hyperdesk:hyperdesk@db:5432/hyperdesk?schema=public

API_PORT=4000
NODE_ENV=development
API_NODE_OPTIONS=--max-old-space-size=384
WEB_NODE_OPTIONS=--max-old-space-size=384
API_MEM_LIMIT=768m
WEB_MEM_LIMIT=768m
MOCK_VNC_MEM_LIMIT=512m
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
ADMIN_EMAIL=admin@hyperdesk.local
ADMIN_PASSWORD=ChangeMe123!
CORS_ORIGIN=http://localhost:3000
HYPERVISOR_PROVIDER=mock
ISO_UPLOAD_DIR=/app/uploads/isos
ISO_MAX_SIZE_MB=10240
API_REQUEST_TIMEOUT_MS=0
VM_SCHEDULER_ENABLED=true
VM_SCHEDULER_INTERVAL_MS=15000
VM_SCHEDULER_BATCH_SIZE=50
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:3000
REMOTE_CONSOLE_TTL_SECONDS=900
REMOTE_CONSOLE_RDP_TUNNEL_MODE=libvirt_ssh
REMOTE_CONSOLE_RDP_TUNNEL_PUBLIC_HOST=auto
REMOTE_CONSOLE_RDP_TUNNEL_PORT_START=13389
REMOTE_CONSOLE_RDP_TUNNEL_PORT_END=13489
REMOTE_CONSOLE_RDP_TUNNEL_READY_TIMEOUT_MS=8000
MOCK_VNC_TARGET_HOST=mock-vnc
MOCK_VNC_TARGET_PORT=5900
DEFAULT_VNC_PORT=5900
DEFAULT_RDP_PORT=3389
MOCK_VNC_PASSWORD=hyperdesk
LIBVIRT_DEFAULT_URI=qemu:///system
LIBVIRT_STORAGE_POOL=default
LIBVIRT_DEFAULT_NETWORK=default
LIBVIRT_VM_NAME_PREFIX=hd
LIBVIRT_DISK_BUS=sata
LIBVIRT_NIC_MODEL=e1000
LIBVIRT_VNC_LISTEN_ADDRESS=0.0.0.0
LIBVIRT_VIDEO_MODEL=vga
LIBVIRT_WINDOWS_VIDEO_MODEL=qxl
LIBVIRT_SOUND_MODEL=ich9
LIBVIRT_VNC_HOST_OVERRIDE=
LIBVIRT_VNC_HOST_FALLBACK=127.0.0.1
LIBVIRT_COMMAND_TIMEOUT_MS=120000
LIBVIRT_ISO_UPLOAD_TIMEOUT_MS=7200000

WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_NOVNC_URL=http://localhost:6081
NEXT_PUBLIC_NOVNC_RESIZE_MODE=remote
